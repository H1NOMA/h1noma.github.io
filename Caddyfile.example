# Пример конфигурации Caddy для КОМИК.
# Это шаблон-подсказка: перенесите нужные директивы в свой боевой Caddyfile.
# Замените домен и путь к статике на свои (комментарии со стрелкой ←).

komikdnd.ru {                      # ← ваш домен
	root * /var/www/komik          # ← путь к каталогу с index.html

	# 1) СЖАТИЕ — главный выигрыш. 20 МБ → ~2–3 МБ «по проводу».
	#    zstd для современных браузеров, gzip как запасной. Caddy сам
	#    выбирает по заголовку Accept-Encoding клиента.
	encode zstd gzip

	# 2) КЭШ-ЗАГОЛОВКИ.
	#    Неизменяемые ассеты (имя меняется редко) — кэшируем надолго.
	@static {
		path *.css *.js *.png *.jpg *.jpeg *.webp *.svg *.woff *.woff2 *.ico *.webmanifest
	}
	header @static Cache-Control "public, max-age=31536000, immutable"
	#    index.html — всегда сверяемся с сервером (внутри уже есть SW-кэш).
	header /index.html Cache-Control "no-cache"
	header / Cache-Control "no-cache"

	# 3) ОТДАЧА ФАЙЛОВ вместо «catch-all».
	#    Реальный файл отдаётся по своему пути; на неизвестный маршрут —
	#    откат на index.html (SPA). Это чинит проблему, из-за которой
	#    вынесенные .json-файлы отдавались как HTML, и открывает путь к
	#    повторному выносу тяжёлых данных в отдельные кэшируемые файлы.
	try_files {path} /index.html
	file_server
}

# --- Необязательно, когда трафик вырастет ---
# Чтобы не сжимать 20 МБ на каждый запрос, можно класть рядом заранее сжатые
# index.html.zst / index.html.gz и включить их отдачу:
#   file_server {
#       precompressed zstd gzip
#   }
# (файлы .zst/.gz нужно пересобирать при каждом изменении index.html —
#  для нынешнего трафика проще оставить on-the-fly `encode` выше.)
